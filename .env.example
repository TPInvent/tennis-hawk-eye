# Supabase credentials for scripts/upload_clips_to_supabase.py
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# Service role key (Project Settings -> API -> service_role secret).
# This has admin storage rights, so keep it out of git and out of the frontend.
SUPABASE_SERVICE_ROLE_KEY=
